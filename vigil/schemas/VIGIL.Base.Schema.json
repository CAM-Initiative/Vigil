{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "VIGIL.Base.Schema.json",
  "description": "Base rules for individual VIGIL records. source_records is the only canonical source-evidence block; source_data is forbidden anywhere in an individual record.",
  "type": "object",
  "required": [
    "id",
    "record_type",
    "record_state",
    "date_recorded",
    "record_identity",
    "summary",
    "evidence_confidence",
    "source_records",
    "system_context",
    "jurisdictional_context",
    "linked_records",
    "cam_internal"
  ],
  "not": {
    "required": [
      "source_data"
    ]
  },
  "properties": {
    "source_records": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source_url_status": {
            "type": "string",
            "enum": [
              "available",
              "available / canonical main-branch confirmed",
              "available / canonical main-branch confirmation pending exact line review",
              "VIGIL local / pending public record URL if applicable",
              "available / pending archive and evidence verification",
              "inaccessible",
              "not applicable",
              "missing_url_requires_research",
              "not applicable — repository/internal observation",
              "not available",
              "local / pending canonical repository confirmation",
              "local / staged in GitHub Codespaces pending canonical repository confirmation",
              "available to authenticated account holder",
              "not applicable — direct incident testimony"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "source_data": false,
    "system_context": {
      "type": "object",
      "required": [
        "platform_or_vendor",
        "product_or_service",
        "specific_model_or_runtime",
        "interface_surface"
      ],
      "description": "Observed/proposed external system, product, service, interface, deployment, or governance corpus context using normalised platform/vendor and product/service fields.",
      "properties": {
        "platform_or_vendor": {
          "type": "string",
          "enum": [
            "OpenAI",
            "xAI",
            "Anthropic",
            "Meta",
            "Google",
            "DeepSeek",
            "Kimi",
            "Sesame",
            "Cohere",
            "Perplexity",
            "Mistral",
            "Microsoft",
            "GitHub",
            "TikTok",
            "Apple",
            "Amazon",
            "Nvidia",
            "Hugging Face",
            "Stability AI",
            "Runway",
            "Midjourney",
            "Adobe",
            "Character.AI",
            "Replit",
            "Notion",
            "Cursor",
            "Replika",
            "Nomi",
            "Chai",
            "Chub.ai",
            "Candy AI",
            "Kindroid",
            "Pi",
            "HammerAI",
            "Snap",
            "Google Play",
            "CAM Initiative",
            "Multi Vendor",
            "Other",
            "Unknown",
            "Not applicable"
          ]
        },
        "vendor_cluster": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "primary_evidenced_vendors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "comparative_vendor_notes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "product_or_service": {
          "type": "string",
          "enum": [
            "ChatGPT",
            "Claude",
            "Gemini",
            "Grok",
            "Copilot",
            "Codex",
            "Claude Code",
            "Deep Research",
            "Perplexity Assistant",
            "Llama",
            "Le Chat",
            "GitHub Copilot",
            "TikTok",
            "X",
            "Replit Agent",
            "Cursor",
            "Midjourney",
            "Runway",
            "Firefly",
            "Character.AI",
            "Replika",
            "Nomi",
            "Chai",
            "Chub.ai",
            "Candy AI",
            "Kindroid",
            "Pi",
            "HammerAI",
            "Snapchat",
            "Google Play",
            "Caelestis Architecture Model",
            "VIGIL",
            "Other",
            "Unknown",
            "Not applicable"
          ]
        },
        "specific_model_or_runtime": {
          "type": "string",
          "minLength": 1
        },
        "interface_surface": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            }
          ]
        }
      },
      "not": {
        "anyOf": [
          {
            "required": [
              "product_family"
            ]
          },
          {
            "required": [
              "specific_model"
            ]
          }
        ]
      }
    },
    "cam_internal": {
      "type": "object",
      "description": "CAM routing, targets, affected areas, or changed components. Preferred instrument fields are related_or_similar_instruments for OBS, affected_instruments for FM, target_instruments for PROP, and changed_instruments for PATCH.",
      "properties": {
        "related_or_similar_instruments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "affected_instruments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "target_instruments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "changed_instruments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "linked_records": {
      "type": "object",
      "description": "Record links. standards is reserved for external standards, laws, regulatory instruments, technical standards, or external governance references; CAM/VIGIL internal references belong in cam_internal routing fields.",
      "properties": {
        "standards": {
          "type": "array"
        },
        "related_observations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "related_failure_modes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "related_proposals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "related_patch_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contextual_relations": {
          "type": "array",
          "description": "Typed, non-transitive context links. These records may inform interpretation but never enter an evidence-to-repair chain.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "record_id",
              "relationship",
              "chain_inclusion",
              "rationale"
            ],
            "properties": {
              "record_id": {
                "type": "string",
                "pattern": "^VIGIL-[0-9]{4}-(OBS|FM|PROP|PATCH|RESEARCH)-[0-9]{4}$"
              },
              "relationship": {
                "type": "string",
                "enum": [
                  "adjacent",
                  "adjacent-control",
                  "contrast",
                  "supporting-mechanism",
                  "shared-corpus-area",
                  "consequential-benefit",
                  "implementation-precedent",
                  "separate-workstream",
                  "governance-context",
                  "research-context"
                ]
              },
              "chain_inclusion": {
                "const": false
              },
              "rationale": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "research": {
          "type": "array",
          "description": "Related VIGIL research artefacts that may provide the evidence origin for this record.",
          "items": {
            "type": "string",
            "pattern": "^VIGIL-[0-9]{4}-RESEARCH-[0-9]{4}$"
          }
        }
      }
    },
    "repair_scope": {
      "type": "object",
      "description": "Authoritative failure-mode scope for a proposal or PATCH. Contextual records belong in linked_records.contextual_relations and do not participate in repair traversal.",
      "additionalProperties": false,
      "required": [
        "primary_failure_mode",
        "additional_resolved_failure_modes",
        "multi_failure_mode_exception",
        "exception_rationale",
        "verification_by_failure_mode"
      ],
      "properties": {
        "primary_failure_mode": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^VIGIL-[0-9]{4}-FM-[0-9]{4}$"
        },
        "additional_resolved_failure_modes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^VIGIL-[0-9]{4}-FM-[0-9]{4}$"
          }
        },
        "multi_failure_mode_exception": {
          "type": "boolean"
        },
        "exception_rationale": {
          "type": [
            "string",
            "null"
          ]
        },
        "verification_by_failure_mode": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": [
              "verified",
              "partially-verified",
              "unverified",
              "not-applicable"
            ]
          }
        }
      }
    },
    "record_state": {
      "type": "string",
      "enum": [
        "draft",
        "scaffolding",
        "active",
        "monitoring",
        "closed-actioned",
        "closed-no-action",
        "deferred",
        "superseded"
      ],
      "description": "VIGIL maintainer workflow state, separate from ecosystem_status, repair_status, resolution_status, and corpus_coverage."
    }
  }
}
