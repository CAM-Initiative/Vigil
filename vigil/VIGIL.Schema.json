  "validator_failure_rules": [
    "Invalid JSON syntax must fail.",
    "Missing required top-level fields must fail.",
    "Missing required nested fields must fail.",
    "Forbidden fields for the record type must fail.",
    "id, record_identity.record_id, and filename stem mismatch must fail unless explicitly permitted by migration mode.",
    "record_type and ID prefix mismatch must fail.",
    "source_records without source_data.sources must fail.",
    "source_data.sources/source_records length mismatch must fail.",
    "Source key loss between source_records and source_data.sources must fail.",
    "Proposal self-link as patch note must fail.",
    "Patch Note without date_implemented must fail.",
    "Patch Note without implementation_verification must fail."
  ],
  "validator_warning_rules": [
    "Unknown jurisdiction may warn but should not fail.",
    "Empty optional arrays may warn only when the record type expects substantive links.",
    "Unresolved linked records may warn in draft mode.",
    "Evidence confidence unknown may warn for failure modes and patch notes.",
    "Source URL unavailable may warn unless evidence_availability is also unavailable and explanation is present."
  ],
  "implementation_notes_for_codex": [
    "Do not redesign record classes.",
    "Do not infer missing evidence.",
    "Do not rewrite existing records during schema implementation unless the user explicitly requests migration.",
    "Create separate schema files per record type and a combined oneOf record schema.",
    "Update validation scripts to enforce semantic invariants that JSON Schema cannot express.",
    "Add fixtures for valid and invalid examples of each record type.",
    "Do not loosen validation to make malformed records pass."
  ]
