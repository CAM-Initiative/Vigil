{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "VIGIL.Proposal.Schema.json",
  "description": "Proposal records require rationale, type, non-empty scope, implementation notes, external relevance, and next action; patch_status and completed implementation claims are forbidden.",
  "allOf": [
    {
      "$ref": "VIGIL.Base.Schema.json"
    }
  ],
  "properties": {
    "record_type": {
      "const": "proposal"
    },
    "proposal_scope": {
      "type": "object",
      "minProperties": 1
    },
    "patch_status": false
  },
  "required": [
    "proposal_rationale",
    "proposal_type",
    "proposal_scope",
    "implementation_notes",
    "external_relevance",
    "next_action"
  ],
  "not": {
    "anyOf": [
      {
        "required": [
          "source_data"
        ]
      },
      {
        "required": [
          "patch_status"
        ]
      },
      {
        "required": [
          "date_implemented"
        ]
      },
      {
        "required": [
          "change_classification"
        ]
      },
      {
        "required": [
          "implementation_verification"
        ]
      }
    ]
  }
}
