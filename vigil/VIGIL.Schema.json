{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/cam/vigil/VIGIL.Schema.json",
  "version": "2.0-clean-design",
  "purpose": "Authoritative schema-rules contract for VIGIL individual records and generated registers. It states the record-class boundaries implemented by vigil/scripts/validate-vigil-records.py without redesigning the ontology.",
  "source_evidence_rules": {
    "individual_records": [
      "source_records is the only canonical source-evidence block in individual records.",
      "source_data is forbidden in individual records.",
      "source_data.sources is forbidden in individual records.",
      "linked_records.external_references must not duplicate the primary evidence source already held in source_records."
    ],
    "generated_registers": [
      "Generated registers may contain derived source_summary fields.",
      "source_summary is derived from source_records and is not maintained by individual record files."
    ]
  },
  "record_classes": {
    "observation": {
      "id_prefix": "OBS",
      "description": "Observation / early warning / source preservation record.",
      "required_top_level_fields": ["id", "record_type", "record_state", "date_recorded", "record_identity", "summary", "evidence_confidence", "source_records", "system_context", "jurisdictional_context", "linked_records", "cam_internal", "next_action"],
      "forbidden_top_level_fields": ["source_data", "failure_classification", "triage", "proposal_scope", "change_classification", "date_implemented", "proposal_rationale", "implementation_notes", "external_relevance", "change_details", "implementation_verification", "impact_summary", "remaining_work", "failure_mode_definition", "failure_threshold"],
      "cam_routing": "Use related_or_similar_* fields only. OBS does not contain failure classification, proposal logic, or patch logic."
    },
    "failure_mode": {
      "id_prefix": "FM",
      "description": "Failure Mode / triage record.",
      "required_top_level_fields": ["id", "record_type", "record_state", "date_recorded", "record_identity", "summary", "failure_mode_definition", "failure_threshold", "evidence_confidence", "source_records", "system_context", "failure_classification", "triage", "jurisdictional_context", "linked_records", "cam_internal"],
      "forbidden_top_level_fields": ["source_data", "proposal_rationale", "proposal_scope", "change_classification", "date_implemented", "change_details", "implementation_verification", "impact_summary", "remaining_work"],
      "cam_routing": "Use affected_* fields for triage-relevant CAM routing."
    },
    "proposal": {
      "id_prefix": "PROP",
      "description": "CAM-specific proposal record.",
      "required_top_level_fields": ["id", "record_type", "record_state", "date_recorded", "record_identity", "summary", "proposal_rationale", "proposal_scope", "implementation_notes", "external_relevance", "next_action", "evidence_confidence", "source_records", "linked_records", "cam_internal"],
      "forbidden_top_level_fields": ["source_data", "change_classification", "date_implemented", "change_details", "implementation_verification", "impact_summary", "remaining_work", "failure_mode_definition", "failure_threshold", "triage", "failure_classification"],
      "cam_routing": "Use target_* fields. A PROP must not claim implementation as a completed patch."
    },
    "patch": {
      "id_prefix": "PATCH",
      "description": "Implemented CAM patch note.",
      "required_top_level_fields": ["id", "record_type", "record_state", "date_recorded", "record_identity", "summary", "date_implemented", "change_classification", "change_details", "implementation_verification", "impact_summary", "remaining_work", "evidence_confidence", "source_records", "linked_records", "cam_internal"],
      "forbidden_top_level_fields": ["source_data", "proposal_rationale", "proposal_scope", "external_relevance", "failure_mode_definition", "failure_threshold", "triage", "failure_classification"],
      "cam_routing": "Use changed_* fields. PATCH records require implemented-change evidence."
    }
  },
  "$defs": {
    "record_type": {"enum": ["observation", "failure_mode", "proposal", "patch"]},
    "evidence_confidence": {"enum": ["verified", "corroborated", "unverified", "anecdotal", "disputed", "unknown", "not applicable", "to be assessed"]},
    "source_type": {"enum": ["linked-observation", "linked-failure-mode", "news-report", "official-source", "social-platform-observation", "platform-behaviour-observation", "third-party-report", "research-source", "standards-source", "repository-source", "governance-note", "deep-research-agent", "other", "not applicable"]},
    "source_record": {"required": ["source_title", "author_or_publisher", "source_date", "source_url", "archive_url", "retrieved_date", "source_type", "source_platform", "system_or_product", "model_or_algorithm", "deployment_context", "source_context", "source_url_status", "relevance_note"]},
    "vigil_record": {"required": ["id", "record_type", "record_state", "date_recorded", "record_identity", "summary", "evidence_confidence", "source_records", "linked_records", "cam_internal"]}
  }
}
