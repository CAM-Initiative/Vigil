{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "VIGIL.Observation.Schema.json",
  "description": "Observation records preserve source evidence without failure classification, triage, proposal, or patch logic. OBS may contain possible_taxonomy_mapping only for unconfirmed taxonomy mapping.",
  "allOf": [
    {
      "$ref": "VIGIL.Base.Schema.json"
    }
  ],
  "properties": {
    "record_type": {
      "const": "observation"
    },
    "possible_taxonomy_mapping": {
      "type": "object"
    }
  },
  "required": [
    "next_action"
  ],
  "not": {
    "anyOf": [
      {
        "required": [
          "source_data"
        ]
      },
      {
        "required": [
          "failure_classification"
        ]
      },
      {
        "required": [
          "triage"
        ]
      },
      {
        "required": [
          "proposal_scope"
        ]
      },
      {
        "required": [
          "change_classification"
        ]
      },
      {
        "required": [
          "date_implemented"
        ]
      }
    ]
  }
}
