{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/cam/vigil/VIGIL.Schema.json",
  "title": "VIGIL Records",
  "description": "Minimal schema for generated VIGIL aggregate files and individual VIGIL observation/workflow records. VIGIL is a public observation layer and does not create CAM doctrine or amend adopted instruments.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_from",
    "generated_at_utc",
    "record_count",
    "records",
    "filename",
    "id"
  ],
  "properties": {
    "generated_notice": {
      "type": "string"
    },
    "generated_from": {
      "type": "string"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "record_count": {
      "type": "integer"
    },
    "records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/vigil_record"
      }
    },
    "filename": {
      "type": "string",
      "pattern": "^VIGIL-\\d{4}-(OBS|FM|RESEARCH|CLUSTER|PROP|PATCH|XWALK)-\\d{4}\\.json$",
      "description": "Filename identifier matching conventions like VIGIL-2026-OBS-0001.json, VIGIL-2026-RESEARCH-0001.json, VIGIL-2026-CLUSTER-0001.json, VIGIL-2026-PROP-0001.json"
    },
    "id": {
      "type": "string",
      "description": "Top-level bundle identifier (must be unique)."
    }
  },
  "$defs": {
    "record_type": {
      "type": "string",
      "enum": [
        "emerging-tech-signal",
        "failure-mode-observation",
        "proposal-development-expansion",
        "cluster",
        "observation",
        "failure_mode",
        "proposal",
        "patch",
        "crosswalk"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "open",
        "watching",
        "clustered",
        "routed",
        "deferred",
        "closed-no-action",
        "closed-actioned"
      ]
    },
    "evidence_confidence": {
      "type": "string",
      "enum": [
        "verified",
        "corroborated",
        "unverified",
        "anecdotal",
        "disputed",
        "unknown"
      ]
    },
    "source_type": {
      "type": "string",
      "enum": [
        "deep-research-agent",
        "automated-search",
        "news-report",
        "official-source",
        "academic-source",
        "standards-source",
        "social-platform-observation",
        "platform-behaviour-observation",
        "repository-observation",
        "third-party-report",
        "other"
      ]
    },
    "source_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "author_or_publisher",
        "source_date",
        "url",
        "archive_url",
        "retrieved_date",
        "source_type",
        "relevance_note"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "author_or_publisher": {
          "type": "string"
        },
        "source_date": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "archive_url": {
          "type": "string"
        },
        "retrieved_date": {
          "type": "string"
        },
        "source_type": {
          "$ref": "#/$defs/source_type"
        },
        "platform": {
          "type": "string",
          "description": "Platform, provider, organisation, or ecosystem actor associated with this source, where known."
        },
        "system_or_product": {
          "type": "string",
          "description": "Product, service, system, algorithmic layer, or deployed interface associated with this source."
        },
        "model_or_algorithm": {
          "type": "string",
          "description": "Specific model, algorithm, recommender, classifier, agent, or runtime system implicated by this source, where known."
        },
        "deployment_context": {
          "type": "string",
          "description": "Context in which the sourced system was observed or described."
        },
        "relevance_note": {
          "type": "string"
        },
        "source_context": {
          "type": "string"
        },
        "source_url_status": {
          "type": "string"
        }
      }
    },
    "vigil_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "record_type",
        "status",
        "date_recorded",
        "summary",
        "why_it_matters_to_CAM",
        "evidence_confidence",
        "source_records",
        "possible_CAM_mapping",
        "next_action"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "record_type": {
          "$ref": "#/$defs/record_type"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "date_observed": {
          "type": "string"
        },
        "date_recorded": {
          "type": "string"
        },
        "date_reviewed": {
          "type": "string",
          "description": "Date the VIGIL record was last reviewed without necessarily being closed."
        },
        "recorded_by": {
          "type": "string"
        },
        "reviewed_by": {
          "type": "string",
          "description": "Person, steward, or process that reviewed the VIGIL record."
        },
        "summary": {
          "type": "string"
        },
        "review_observation": {
          "type": "string",
          "description": "Short reviewer note describing what was observed, changed, confirmed, deferred, or left unresolved during review."
        },
        "why_it_matters_to_CAM": {
          "type": "string"
        },
        "evidence_confidence": {
          "$ref": "#/$defs/evidence_confidence"
        },
        "source_records": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_record"
          }
        },
        "platform": {
          "type": "string",
          "description": "Primary platform, provider, organisation, or ecosystem actor associated with the observation, where known."
        },
        "system_or_product": {
          "type": "string",
          "description": "Product, service, system, algorithmic layer, or deployed interface associated with the observation."
        },
        "model_or_algorithm": {
          "type": "string",
          "description": "Specific model, algorithm, recommender, classifier, agent, or runtime system implicated by the observation, where known."
        },
        "deployment_context": {
          "type": "string",
          "description": "Context in which the system was observed, such as web app, mobile app, API, enterprise deployment, social platform, content moderation system, recommendation system, or repository automation."
        },
        "ecosystem_area": {
          "type": "string",
          "description": "Broad ecosystem area implicated by the observation, such as AI assistant, social platform, search, content moderation, recommender systems, cloud infrastructure, developer tooling, synthetic media, neurotechnology, or public legitimacy layer."
        },
        "failure_mode": {
          "type": "string",
          "description": "Specific observed failure mode or governance pattern described by the record."
        },
        "next_action": {
          "type": "string"
        },
        "cluster_id": {
          "type": "string"
        },
        "related_record_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "supersedes_record_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "candidate_amendment_id": {
          "type": "string"
        },
        "possible_CAM_mapping": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "affected_domains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "affected_instruments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failure_family": {
          "type": "string"
        },
        "amendment_class": {
          "type": "string"
        },
        "governance_drift_type": {
          "type": "string"
        },
        "provenance_notes": {
          "type": "string",
          "description": "Optional notes describing provenance assumptions, provisional mappings, or calibration needs for the record."
        },
        "closure_outcome": {
          "type": "string"
        },
        "closure_notes": {
          "type": "string"
        },
        "actioned_by": {
          "type": "string"
        },
        "date_closed": {
          "type": "string"
        },
        "record_identity": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "record_id": {
              "$ref": "#/$defs/record_id"
            },
            "record_type": {
              "$ref": "#/$defs/record_type"
            },
            "title": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "created": {
              "type": "string"
            },
            "updated": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          },
          "required": [
            "record_id",
            "record_type",
            "title",
            "status"
          ],
          "description": "Stable public record identity."
        },
        "source_data": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "source_type": {
              "type": "string"
            },
            "source_url": {
              "type": "string"
            },
            "source_platform": {
              "type": "string"
            },
            "source_author_or_account": {
              "type": "string"
            },
            "date_observed": {
              "type": "string"
            },
            "date_published": {
              "type": "string"
            },
            "archive_status": {
              "type": "string"
            },
            "evidence_availability": {
              "type": "string"
            },
            "evidence_confidence": {
              "type": "string"
            },
            "reproducibility": {
              "type": "string"
            },
            "primary_source_url": {
              "type": "string"
            },
            "primary_source_platform": {
              "type": "string"
            },
            "primary_source_author_or_account": {
              "type": "string"
            },
            "sources": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/source_item"
              },
              "description": "Canonical v2 source preservation array copied from legacy source_records without source-level field loss."
            }
          },
          "description": "External source evidence. Required in substance for observations; may be minimal or not applicable for reusable classifications and proposals."
        },
        "system_context": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "system_type": {
              "type": "string"
            },
            "platform_or_vendor": {
              "type": "string"
            },
            "model_or_product": {
              "type": "string"
            },
            "interaction_mode": {
              "type": "string"
            },
            "embodiment_status": {
              "type": "string"
            },
            "deployment_context": {
              "type": "string"
            },
            "user_role": {
              "type": "string"
            },
            "affected_population": {
              "type": "string"
            }
          }
        },
        "jurisdictional_context": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "primary_jurisdiction": {
              "type": "string"
            },
            "secondary_jurisdictions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "regulatory_surface": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "sector": {
              "type": "string"
            },
            "cross_border_relevance": {
              "type": "string"
            },
            "public_interest_relevance": {
              "type": "string"
            }
          }
        },
        "failure_classification": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "failure_mode_ids": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "failure_family": {
              "type": "string"
            },
            "harm_vectors": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "severity": {
              "type": "string"
            },
            "likelihood": {
              "type": "string"
            },
            "confidence": {
              "type": "string"
            },
            "affected_rights_or_interests": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "linked_records": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "observations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "failure_modes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "proposals": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "patches": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "external_references": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/external_reference"
              }
            }
          }
        },
        "cam_internal": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "affected_instruments": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "affected_annexes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "affected_domains": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "governance_layer": {
              "type": "string"
            },
            "patch_status": {
              "type": "string"
            },
            "validator_or_automation_impact": {
              "type": "string"
            }
          },
          "description": "CAM internal routing metadata; not the public primary classification layer."
        },
        "robotics_context": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "robot_class": {
              "type": "string"
            },
            "mobility_type": {
              "type": "string"
            },
            "actuation_capability": {
              "type": "string"
            },
            "physical_environment": {
              "type": "string"
            },
            "proximity_to_humans": {
              "type": "string"
            },
            "safety_boundary": {
              "type": "string"
            },
            "human_override_available": {
              "type": "string"
            },
            "emergency_stop_available": {
              "type": "string"
            },
            "operator_present": {
              "type": "string"
            },
            "physical_harm_potential": {
              "type": "string"
            },
            "property_harm_potential": {
              "type": "string"
            }
          },
          "description": "Optional extension for robotics or embodied-system observations."
        },
        "failure_mode_details": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "failure_mode_id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "definition": {
              "type": "string"
            },
            "applicable_system_types": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "known_observations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "known_proposals": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "harm_vectors": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "mitigation_pathways": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "jurisdictional_or_sector_relevance": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "description": "Reusable classification details for record_identity.record_type=failure_mode."
        },
        "migration_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "legacy_record_type": {
          "type": "string"
        }
      }
    },
    "source_item": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "title",
        "author_or_publisher",
        "source_date",
        "url",
        "archive_url",
        "retrieved_date",
        "source_type",
        "platform",
        "system_or_product",
        "model_or_algorithm",
        "deployment_context",
        "source_context",
        "source_url_status",
        "relevance_note"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "author_or_publisher": {
          "type": "string"
        },
        "source_date": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "archive_url": {
          "type": "string"
        },
        "retrieved_date": {
          "type": "string"
        },
        "source_type": {
          "$ref": "#/$defs/source_type"
        },
        "platform": {
          "type": "string"
        },
        "system_or_product": {
          "type": "string"
        },
        "model_or_algorithm": {
          "type": "string"
        },
        "deployment_context": {
          "type": "string"
        },
        "source_context": {
          "type": "string"
        },
        "source_url_status": {
          "type": "string"
        },
        "relevance_note": {
          "type": "string"
        }
      }
    }
  }
}
