{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "VIGIL.PatchNote.Schema.json",
  "description": "Patch Note records require implemented change date, classification, details, verification, impact summary, and remaining work.",
  "allOf": [
    {
      "$ref": "VIGIL.Base.Schema.json"
    }
  ],
  "properties": {
    "record_type": {
      "enum": [
        "patch",
        "patch_note"
      ]
    },
    "change_details": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    },
    "implementation_verification": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    }
  },
  "required": [
    "date_implemented",
    "change_classification",
    "change_details",
    "implementation_verification",
    "impact_summary",
    "remaining_work"
  ],
  "not": {
    "required": [
      "source_data"
    ]
  }
}
