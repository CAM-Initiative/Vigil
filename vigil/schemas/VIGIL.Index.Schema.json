{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "VIGIL.Index.Schema.json",
  "description": "Generated VIGIL type registry and master registry index schema. Non-PATCH entries are compact manifests; PATCH entries additionally carry the public decision trace, literal corpus implementation, and reconstruction disclosure required for direct interface rendering.",
  "oneOf": [
    {
      "$ref": "#/$defs/type_registry"
    },
    {
      "$ref": "#/$defs/master_registry"
    }
  ],
  "$defs": {
    "url": {
      "type": "string",
      "format": "uri"
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "string_or_string_array": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/string_array"
        }
      ]
    },
    "record_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "record_type",
        "record_state",
        "date_recorded",
        "title",
        "summary",
        "evidence_confidence",
        "source_types",
        "path",
        "github_blob_url",
        "raw_url"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "record_type": {
          "type": "string"
        },
        "record_state": {
          "type": "string"
        },
        "date_recorded": {
          "type": "string"
        },
        "date_implemented": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "evidence_confidence": {
          "type": "string"
        },
        "source_types": {
          "$ref": "#/$defs/string_array"
        },
        "source_count": {
          "type": "integer",
          "minimum": 0
        },
        "primary_source_title": {
          "type": "string"
        },
        "primary_source_type": {
          "type": "string"
        },
        "primary_source_platform": {
          "type": "string"
        },
        "source_platforms": {
          "$ref": "#/$defs/string_array"
        },
        "source_url_status": {
          "type": "string"
        },
        "system_type": {
          "type": "string"
        },
        "platform_or_vendor": {
          "type": "string"
        },
        "vendor_cluster": {
          "$ref": "#/$defs/string_array"
        },
        "primary_evidenced_vendors": {
          "$ref": "#/$defs/string_array"
        },
        "product_or_service": {
          "type": "string"
        },
        "specific_model_or_runtime": {
          "type": "string"
        },
        "model_or_product": {
          "type": "string"
        },
        "interface_surface": {
          "type": "string"
        },
        "deployment_context": {
          "type": "string"
        },
        "primary_jurisdiction": {
          "type": "string"
        },
        "regulatory_surface": {
          "$ref": "#/$defs/string_array"
        },
        "sector": {
          "type": "string"
        },
        "canonical_failure_group": {
          "type": "string"
        },
        "failure_family": {
          "type": "string"
        },
        "failure_subtype": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "likelihood": {
          "type": "string"
        },
        "triage_priority": {
          "type": "string"
        },
        "triage_status": {
          "type": "string"
        },
        "mitigation_status": {
          "type": "string"
        },
        "escalation_required": {
          "type": "string"
        },
        "proposal_type": {
          "$ref": "#/$defs/string_or_string_array"
        },
        "proposal_status": {
          "type": "string"
        },
        "proposal_scope_summary": {
          "type": "string"
        },
        "patch_type": {
          "$ref": "#/$defs/string_or_string_array"
        },
        "change_type": {
          "$ref": "#/$defs/string_or_string_array"
        },
        "change_family": {
          "type": "string"
        },
        "change_subtype": {
          "type": "string"
        },
        "change_status": {
          "type": "string"
        },
        "implementation_state": {
          "type": "string"
        },
        "verification_status": {
          "type": "string"
        },
        "ecosystem_status_summary": {
          "type": "object"
        },
        "repair_status_summary": {
          "type": "object"
        },
        "corpus_coverage_summary": {
          "type": "object"
        },
        "resolution_status_summary": {
          "type": "object"
        },
        "coverage_reconciliation_summary": {
          "type": "object"
        },
        "decision_trace": {
          "type": "object"
        },
        "corpus_implementation": {
          "type": "object"
        },
        "record_reconstruction": {
          "type": "object"
        },
        "patch_classifications": {
          "$ref": "#/$defs/string_array"
        },
        "repair_provenance_summary": {
          "type": "object"
        },
        "interpretive_provenance_summary": {
          "type": "object"
        },
        "evidence_access_summary": {
          "type": "object"
        },
        "path": {
          "type": "string",
          "pattern": "^vigil/records/(failures|observations|proposals|patches)/[0-9]{4}/VIGIL-[0-9]{4}-(FM|OBS|PROP|PATCH)-[0-9]+\\.json$"
        },
        "github_blob_url": {
          "$ref": "#/$defs/url"
        },
        "raw_url": {
          "$ref": "#/$defs/url"
        }
      }
    },
    "type_registry": {
      "type": "object",
      "required": [
        "generated_notice",
        "registry_type",
        "generated_from",
        "record_count",
        "records"
      ],
      "properties": {
        "generated_notice": {
          "type": "string"
        },
        "registry_type": {
          "enum": [
            "failure_modes",
            "observations",
            "proposals",
            "patch_notes"
          ]
        },
        "generated_from": {
          "enum": [
            "vigil/records/failures/",
            "vigil/records/observations/",
            "vigil/records/proposals/",
            "vigil/records/patches/"
          ]
        },
        "record_count": {
          "type": "integer",
          "minimum": 0
        },
        "records": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/record_entry"
          }
        }
      }
    },
    "master_registry": {
      "type": "object",
      "required": [
        "generated_notice",
        "registry_type",
        "generated_from",
        "registry_count",
        "record_count",
        "registries",
        "records"
      ],
      "properties": {
        "generated_notice": {
          "type": "string"
        },
        "registry_type": {
          "const": "vigil_registry_master"
        },
        "generated_from": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "registry_count": {
          "const": 4
        },
        "record_count": {
          "type": "object",
          "required": [
            "failure_modes",
            "observations",
            "proposals",
            "patch_notes",
            "total"
          ]
        },
        "registries": {
          "type": "object"
        },
        "records": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/record_entry"
          }
        }
      }
    }
  }
}
