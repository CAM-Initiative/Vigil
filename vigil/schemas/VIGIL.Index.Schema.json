{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "VIGIL.Index.Schema.json",
  "description": "Generated VIGIL register/index schema. Generated registers may contain derived summaries from source_records, system_context, jurisdictional_context, classification, proposal, change, verification, impact, and CAM routing fields according to record class.",
  "type": "object",
  "required": [
    "generated_notice",
    "generated_from",
    "record_count",
    "records"
  ],
  "properties": {
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source_summary": {
            "type": "object"
          },
          "system_summary": {
            "type": "object"
          },
          "jurisdiction_summary": {
            "type": "object"
          },
          "possible_taxonomy_mapping_summary": {
            "type": "object"
          },
          "classification_summary": {
            "type": "object"
          },
          "triage_summary": {
            "type": "object"
          },
          "proposal_summary": {
            "type": "object"
          },
          "external_relevance_summary": {
            "type": "object"
          },
          "change_summary": {
            "type": "object"
          },
          "verification_summary": {
            "type": "object"
          },
          "impact_summary": {
            "type": "object"
          },
          "cam_summary": {
            "type": "object"
          }
        }
      }
    }
  }
}
