  "universal_rules": {
    "id_format": "^VIGIL-[0-9]{4}-(OBS|FM|PROP|PATCH)-[0-9]{4}$",
    "record_identity_consistency": [
      "record_identity.record_id must equal top-level id.",
      "record_identity.record_type must equal top-level record_type.",
      "The ID prefix must match record_type: OBS=observation, FM=failure_mode, PROP=proposal, PATCH=patch_note."
    ],
    "source_preservation": [
      "source_records must not be flattened or discarded.",
      "If source_records exists, source_data.sources must exist.",
      "source_data.sources length must equal source_records length unless the record type explicitly permits empty source_records.",
      "Each source_data.sources item must preserve every key present in the corresponding source_records item.",
      "source_records is authoritative when migrating legacy source data into source_data.sources."
    ],
    "linked_record_integrity": [
      "Linked VIGIL IDs should match the universal VIGIL ID format.",
      "Linked records should resolve to files where strict validation is enabled.",
      "Unresolved linked IDs may warn in draft mode but should fail in release validation unless explicitly marked external or pending.",
      "A proposal must not list itself as a patch note.",
      "A patch note must not claim implementation without date_implemented and implementation_verification."
    ],
    "semantic_separation": [
      "Observation records must not contain failure triage, CAM repair logic, proposal scope, or patch implementation fields.",
      "Failure Mode records must explain why the observation-to-failure threshold has been crossed.",
      "Proposal records describe proposed CAM development and must not claim implementation.",
      "Patch Note records describe implemented changes and must distinguish completed work from remaining work."
    ]
  },
